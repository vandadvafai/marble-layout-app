# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# OS / editor cruft
.DS_Store
*.swp
.vscode/
.idea/

# Generated outputs — ignored per run, but keep the folder structure
# in git via the .gitkeep markers re-included below.
outputs/cad_inspections/**
outputs/dxf_validation_runs/**
outputs/layout_packages/**
outputs/demo_cad_previews/**
outputs/validation_runs/**

# Intermediate DWG → DXF conversion artifacts (never committed).
outputs/intermediate_cad/**
outputs/**/internal/*.dxf
outputs/**/internal/*.dwg

# Local Streamlit UI runs (only the latest run is kept on disk).
outputs/ui_runs/**

# V1 ERP slab ingestion outputs (regenerable from the Excel + images).
outputs/slab_ingestion/**
outputs/slab_ingestion_*/**

# V1 inventory smoke-test outputs (regenerable from clean_slabs.json).
outputs/smoke_placement/**

# V1 image intake outputs (processed slab photos + metadata).
outputs/image_intake/**

# V1 DXF smoke placement outputs (regenerable from DXF + inventory).
outputs/dxf_smoke_placement/**

# V1 polygon-aware DXF placement outputs (regenerable).
outputs/dxf_polygon_placement/**

# V1 layout generator outputs (regenerable from DXF + tile size).
outputs/layouts/**

# V1 cut-list outputs (regenerable from layout.json).
outputs/cut_lists/**

# Local raw ERP fixtures (Excel exports + slab photos). Real customer
# data; never committed. Use --excel / --images to point the V1 script
# at wherever the files actually live.
data/

!outputs/.gitkeep
!outputs/cad_inspections/.gitkeep
!outputs/dxf_validation_runs/.gitkeep
!outputs/layout_packages/.gitkeep
!outputs/demo_cad_previews/.gitkeep
!outputs/intermediate_cad/.gitkeep
!outputs/ui_runs/.gitkeep
!outputs/slab_ingestion/.gitkeep
!outputs/smoke_placement/.gitkeep
!outputs/image_intake/.gitkeep
!outputs/dxf_smoke_placement/.gitkeep
!outputs/dxf_polygon_placement/.gitkeep
!outputs/layouts/.gitkeep
!outputs/cut_lists/.gitkeep

# Duplicate / debug check artifacts
*_check.json
*_check.png
*_check.dxf

# Source test fixtures are NOT ignored:
#   examples/cad_inputs/**/*.dxf      standardized DXF fixtures
#   examples/*.json                   engine-input fixtures used by tests
#   examples/legacy_json_inputs/*.json  retained legacy examples
#   examples/generated/.gitkeep
